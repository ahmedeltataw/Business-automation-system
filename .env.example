# ============================================
# Freelance Sales Automation - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# --- Supabase (PostgreSQL + Auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Table prefix for environment isolation
# Leave empty for production (scraped_jobs)
# Set to "dev_" for development (dev_scraped_jobs)
SUPABASE_TABLE_PREFIX=

# --- Upstash Redis (Distributed Locking) ---
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# --- AI Providers ---
# FreeLLMAPI (unified proxy — 9 providers, single key)
# Dashboard: https://free.llm-api.com
# Models: gemini-2.5-flash, groq/llama-3.3-70b, deepseek-chat, cerebras/qwen3-235b,
#         sambanova/llama-4-scout, cloudflare/kimi-k2.6, github/gpt-4o,
#         zhipu/glm-4.7-flash, cohere/command-r-plus
FREELLM_API_URL=https://free.llm-api.com/v1
FREELLM_API_KEY=your-freellm-api-key

# Gemini API (primary structured analysis)
GEMINI_API_KEY=your-gemini-api-key

# Groq API (primary fast inference)
GROQ_API_KEY=your-groq-api-key

# Optional: Second Groq key for key rotation on rate limits
GROQ_API_KEY_2=

# Hugging Face Inference Providers (fallback)
HF_TOKEN=hf_your-huggingface-token

# --- Telegram Bot "King" ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token

# Your Telegram user ID (for admin-only button actions)
TELEGRAM_CHAT_ID=your-chat-id

# --- Runtime ---
HEADLESS=true
AUTOPILOT_KEEP_ALIVE=true
